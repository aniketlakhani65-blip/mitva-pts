# ============================================================================
# Copy this file to .env and fill in real values before running.
# ============================================================================

# --- Database ----------------------------------------------------------------
# Dev default: SQLite (no install needed, DB file is created on first migrate)
DATABASE_URL="file:./dev.db"
# For production, switch the provider in prisma/schema.prisma to "postgresql"
# and use a URL like: postgresql://user:pass@host:5432/mitva?schema=public

# --- NextAuth ----------------------------------------------------------------
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="change-me-to-a-long-random-string"
NEXTAUTH_URL="http://localhost:3000"

# --- App ---------------------------------------------------------------------
APP_NAME="Mitva PTS"
